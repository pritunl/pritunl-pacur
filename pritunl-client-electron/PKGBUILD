    "oraclelinux-9"
    "oraclelinux-10"
    "ubuntu-noble"
    "ubuntu-questing"
    "ubuntu-resolute"
)
pkgname="pritunl-client-electron"
pkgver="1.3.4655.98"
pkgrel="1"
pkgdesc="Pritunl OpenVPN Electron Client"
pkgdesclong=(
    "Free and open source cross platform OpenVPN client"
)
maintainer="Pritunl <contact@pritunl.com>"
arch="amd64"
license=("custom")
section="utils"
priority="optional"
url="https://github.com/pritunl/pritunl-client"
rpmopts=(
    "%global __requires_exclude (libffmpeg|libEGL|libGLESv2|libvk_swiftshader|libvulkan)\\.so"
    "Provides: config(pritunl-client-electron) = %{version}-%{release}"
    "AutoProv: no"
)
depends:pacman=(
    "libxss"
    "net-tools"
    "iproute2"
    "openvpn"
    "icu"
)
depends:yum=(
    "GConf2"
    "libXScrnSaver"
    "net-tools"
    "iptables"
    "openvpn"
)
depends:apt=(
    "libgtk2.0-0"
    "libxss1"
    "net-tools"
    "iptables"
    "openvpn"
)
makedepends:pacman=(
    "nodejs-lts-jod"
    "npm"
    "python3"
    "libxss"
    "net-tools"
    "iproute2"
    "openvpn"
    "unzip"
    "icu"
)
makedepends:yum=(
    "nodejs22"
    "npm"
    "python3"
    "GConf2"
    "unzip"
)
makedepends:apt=(
    "nodejs"
    "npm"
    "python3"
    "ca-certificates"
    "gnupg"
    "curl"
    "unzip"
)
provides=("${pkgname}")
conflicts=(
    "${pkgname}"
    "pritunl-client"
)
sources=(
    "${url}/archive/refs/tags/${pkgver}.tar.gz"
)
hashsums=(
    "a5d3592d3d3c055d1e50cdda87787ff4b8fe85849f76ccd908456f1232c3d93a"
)
backup=(
    "var/log/pritunl-client.log"
    "var/log/pritunl-client.log.1"
)

build:pacman() {
    cd "${srcdir}/pritunl-client-${pkgver}"

    cd service
    go get
    go install

    cd ../cli
    go get
    go install

    cd ../client
    npm install
    ./node_modules/.bin/electron-rebuild
    ./node_modules/.bin/electron-packager ./ Pritunl --platform=linux --arch=x64 --out=../build/linux
}
build:yum() {
    cd "${srcdir}/pritunl-client-${pkgver}"

    cd service
    go get
    go install

    cd ../cli
    go get
    go install

    cd ../client
    npm install
    ./node_modules/.bin/electron-rebuild
    ./node_modules/.bin/electron-packager ./ Pritunl --platform=linux --arch=x64 --out=../build/linux
